{
  "$schema": "https://irodori.dev/schemas/irodori.extension.schema.json",
  "manifestVersion": 1,
  "id": "irodori.databricks",
  "name": "Databricks Connector",
  "version": "0.1.0",
  "publisher": "irodori",
  "description": "Databricks Connector contributes the Databricks database connector through the native connector ABI.",
  "license": "MIT OR 0BSD",
  "repository": "https://github.com/hjosugi/irodori-extension-databricks",
  "apiVersion": "0.1",
  "runtime": "native",
  "entry": "dist/native",
  "permissions": [
    "connections:read",
    "connections:write",
    "queries:run",
    "metadata:read",
    "native",
    "connectors"
  ],
  "contributes": {
    "connectors": [
      {
        "id": "databricks.connector",
        "engine": "databricks",
        "label": "Databricks",
        "aliases": [
          "databricks",
          "Databricks / Spark SQL",
          "Databricks"
        ],
        "defaultPort": 443,
        "wire": "jdbc",
        "module": "databricks.driver",
        "features": [
          "metadata",
          "sql",
          "explain"
        ]
      }
    ]
  },
  "capabilities": {
    "nativeModules": [
      {
        "id": "databricks.driver",
        "path": "dist/native",
        "platforms": [
          "windowsX64",
          "windowsArm64",
          "macosX64",
          "macosArm64",
          "linuxX64",
          "linuxArm64"
        ]
      }
    ]
  },
  "dev": {
    "watch": [
      "src",
      "connector.config.json",
      "irodori.extension.json"
    ]
  }
}
